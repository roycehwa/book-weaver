# MiniMax (required for default glossary suggest)
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7-highspeed
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic/v1/messages
MINIMAX_HTTP_TIMEOUT_SECONDS=90

# DeepL (required for sensitive books and MiniMax timeout/sensitive fallback)
TRANSLATION_FALLBACK=deepl
DEEPL_AUTH_KEY=
DEEPL_BASE_URL=https://api.deepl.com
DEEPL_HTTP_TIMEOUT_SECONDS=120
DEEPL_MONTHLY_CHAR_BUDGET=1800000

# Glossary suggest tuning
GLOSSARY_SUGGEST_BATCH_SIZE=8
GLOSSARY_SUGGEST_STALE_MINUTES=20
